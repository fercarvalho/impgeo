# Configuração do PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=impgeo
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui

# JWT Secret
JWT_SECRET=impgeo_secret_key_2024

# URL base do frontend (usada em links de recuperação)
BASE_URL=http://localhost:5173

# SendGrid API
SENDGRID_API_KEY=SG.sua_api_key_aqui
SENDGRID_FROM_EMAIL=noreply@seu-dominio.com
SENDGRID_FROM_NAME=IMPGEO
# Opcional: template dinâmico no SendGrid
# SENDGRID_TEMPLATE_ID_RESET=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Recuperação de senha
PASSWORD_RESET_TOKEN_TTL_MINUTES=60
PASSWORD_RESET_CLEANUP_INTERVAL_MINUTES=60

# CORS (origens permitidas, separadas por vírgula)
CORS_ORIGINS=http://localhost:9000

# Criptografia de campos sensíveis (gerar com: openssl rand -base64 32)
ENCRYPTION_KEY=
ENCRYPTION_SALT=impgeo-salt-change-me

# Sessões ativas
MAX_SESSIONS_PER_USER=5

# Alertas de segurança por email
ALERT_EMAIL_FROM=security@impgeo.com
ALERT_EMAIL_TO=admin@impgeo.com

# Anomaly Detection (thresholds opcionais)
# MAX_REQUESTS_PER_MINUTE=60
# MAX_FAILED_LOGINS_PER_HOUR=10
# UNUSUAL_HOUR_START=2
# UNUSUAL_HOUR_END=6
